<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:gravity="center"
    android:background="#FFFFFF">

    <TextView
        android:text="📝 Cadastro"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E63946"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/editNomeCadastro"
        android:hint="Nome completo"
        android:inputType="textPersonName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:padding="15dp"
        android:background="@drawable/edittext_border"/>

    <EditText
        android:id="@+id/editEmailCadastro"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:padding="15dp"
        android:background="@drawable/edittext_border"/>

    <EditText
        android:id="@+id/editSenhaCadastro"
        android:hint="Senha"
        android:inputType="textPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:padding="15dp"
        android:background="@drawable/edittext_border"/>

    <EditText
        android:id="@+id/editVeiculoCadastro"
        android:hint="Veículo (apenas para entregador)"
        android:inputType="textPersonName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="25dp"
        android:padding="15dp"
        android:background="@drawable/edittext_border"/>

    <Button
        android:id="@+id/btnCadastrar"
        android:text="Cadastrar"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E63946"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:padding="15dp"/>

    <TextView
        android:id="@+id/textVoltarLogin"
        android:text="Já tem conta? Faça login"
        android:textColor="#E63946"
        android:textSize="14sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>