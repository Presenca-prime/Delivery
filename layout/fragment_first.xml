<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:gravity="center"
    android:background="@color/white">

    <TextView
        android:text="🍔 Prime Delivery"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E63946"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"/>

    <RadioGroup
        android:id="@+id/radioGroupTipo"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center">

        <RadioButton
            android:id="@+id/radioCliente"
            android:text="👤 Cliente"
            android:checked="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"/>

        <RadioButton
            android:id="@+id/radioEntregador"
            android:text="🛵 Entregador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RadioGroup>

    <EditText
        android:id="@+id/editEmailLogin"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:padding="15dp"
        android:background="@drawable/edittext_border"/>

    <EditText
        android:id="@+id/editSenhaLogin"
        android:hint="Senha"
        android:inputType="textPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="25dp"
        android:padding="15dp"
        android:background="@drawable/edittext_border"/>

    <Button
        android:id="@+id/btnEntrar"
        android:text="Entrar"
        android:textColor="@color/white"
        android:backgroundTint="#E63946"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:padding="15dp"/>

    <TextView
        android:id="@+id/textCadastrar"
        android:text="Não tem conta? Cadastre-se"
        android:textColor="#E63946"
        android:textSize="14sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"/>

</LinearLayout>